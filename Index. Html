    }
    button.secondary{background:rgba(255,255,255,.06);box-shadow:none}
    button.danger{background:rgba(251,113,133,.15)}
    button:active{transform:translateY(1px)}

    .toggleRow{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .toggle{
      display:flex;align-items:center;gap:10px;
      padding:10px;border-radius:12px;border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);color:rgba(255,255,255,.88);user-select:none;
    }
    .toggle input{width:auto}

    .list{
      border-radius:var(--radius);
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.03);
    }
    .item{
      padding:12px;border-bottom:1px solid rgba(255,255,255,.08);
      display:grid;gap:6px;cursor:pointer;
    }
    .item:last-child{border-bottom:none}
    .item.selected{outline:2px solid rgba(124,92,255,.55);background:rgba(124,92,255,.10)}
    .row{display:flex;align-items:center;justify-content:space-between;gap:10px}
    .name{font-weight:760}
    .meta{color:var(--muted);font-size:12px}
    .tags{display:flex;flex-wrap:wrap;gap:6px;align-items:center}
    .tag{
      font-size:11px;padding:4px 8px;border-radius:999px;
      border:1px solid rgba(124,92,255,.28);background:rgba(124,92,255,.14);
      color:rgba(230,225,255,.92);
      max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap
    }
    .tag.good{border-color:rgba(45,212,191,.35);background:rgba(45,212,191,.13)}
    .tag.warn{border-color:rgba(251,113,133,.38);background:rgba(251,113,133,.12)}
    .footer{display:flex;align-items:center;justify-content:space-between;gap:10px;color:var(--muted);font-size:12px}

    iframe,video{width:100%;height:100%;border:0;background:#000}

    .overlayTop{
      position:absolute;top:12px;left:12px;right:12px;
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      pointer-events:none;z-index:9;
    }
    .chip{
      background:rgba(0,0,0,.45);border:1px solid rgba(255,255,255,.12);
      padding:8px 10px;border-radius:999px;color:rgba(255,255,255,.90);
      font-size:12px;max-width:60%;
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    }

    .touchBar{
      position:absolute;left:12px;right:12px;bottom:12px;
      display:flex;gap:8px;flex-wrap:wrap;
      justify-content:center;align-items:center;
      z-index:10;
    }
    .touchBtn{
      pointer-events:auto;
      border-radius:999px;padding:10px 14px;
      background:rgba(0,0,0,.42);
      border:1px solid rgba(255,255,255,.14);
      color:rgba(255,255,255,.92);
      box-shadow: var(--shadow);
      user-select:none;font-size:13px;
    }
    .touchBtn.good{ border-color: rgba(45,212,191,.5); background: rgba(45,212,191,.16); }
    .touchBtn.warn{ border-color: rgba(251,113,133,.55); background: rgba(251,113,133,.18); }
    .touchBtn.on{ border-color: rgba(124,92,255,.6); background: rgba(124,92,255,.22); }

    .callout{
      border-radius:16px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.05);
      padding:12px;
      display:grid;
      gap:8px;
    }
    .callout b{color:rgba(255,255,255,.95)}
    .callout small{color:var(--muted);line-height:1.35}
  </style>
</head>
<body>

<div class="app">
  <aside class="guide" id="guide">
    <div class="hdr">
      <div class="title">Free TV <span class="pill">v12.2.1</span></div>
      <div class="pill" id="clock">--:--</div>
    </div>

    <div class="sub">
      If the list is empty on Android <code>content://</code>, use <b>Import English Playlist</b> below (or Import File).
    </div>

    <div class="callout" id="emptyCallout" style="display:none">
      <b>No channels loaded</b>
      <small>
        This usually happens when opening local HTML as <code>content://</code> and the playlist fetch fails.
        Tap Import below. If it fails, download the playlist and use Import File.
      </small>
      <div class="controls" style="grid-template-columns:1fr 1fr">
        <button id="btnImportEng">Import English Playlist</button>
        <button class="secondary" id="btnImportFileTop">Import File</button>
      </div>
    </div>

    <div class="controls">
      <input id="q" placeholder="Search (name/tags/url)" />
      <select id="group"><option value="">Group (all)</option></select>
      <select id="lang"><option value="">Language (all)</option></select>
      <select id="type">
        <option value="">Type (all)</option>
        <option value="news">News</option>
        <option value="sports">Sports</option>
        <option value="movies">Movies</option>
        <option value="music">Music</option>
        <option value="education">Education</option>
        <option value="general">General</option>
      </select>
    </div>

    <div class="toggleRow">
      <label class="toggle"><input type="checkbox" id="playableOnly"/> Playable only (HLS/MP4)</label>
      <label class="toggle"><input type="checkbox" id="hideAudioOnly"/> Hide audio-only</label>
      <label class="toggle"><input type="checkbox" id="autoScroll"/> Guide autoscroll</label>
      <label class="toggle"><input type="checkbox" id="autoTheater"/> Auto theater on idle</label>
    </div>

    <div class="controls">
      <button class="secondary" id="btnOpenTab">Open Tab</button>
      <button class="secondary" id="btnResetUI">Reset UI</button>
    </div>

    <div class="list" id="list"></div>

    <div class="footer">
      <div id="status">Ready</div>
      <div id="count">0</div>
    </div>
  </aside>

  <main class="player" id="player">
    <iframe id="pvFrame"
      sandbox="allow-scripts allow-forms allow-same-origin allow-popups allow-presentation"
      allow="autoplay; encrypted-media; picture-in-picture; fullscreen"
      referrerpolicy="strict-origin-when-cross-origin"
      style="display:none"></iframe>

    <video id="pvVideo" controls playsinline style="display:block"></video>

    <div class="overlayTop">
      <div class="chip" id="nowPlaying">No channel</div>
      <div class="chip" id="modeBadge">mode: —</div>
    </div>

    <div class="touchBar">
      <div class="touchBtn" id="tPrev">⟵ Prev</div>
      <div class="touchBtn good" id="tPlay">▶ Play</div>
      <div class="touchBtn" id="tNext">Next ⟶</div>
      <div class="touchBtn" id="tTheater">⬛ Theater</div>
      <div class="touchBtn" id="tFS">⛶ Fullscreen</div>
      <div class="touchBtn warn" id="tRecover">🧯 Recover</div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.18/dist/hls.min.js"></script>
<script>
(() => {
  const DEFAULT_ENG_PLAYLIST = "https://iptv-org.github.io/iptv/languages/eng.m3u";
  const KEY = "free_tv_v12_2_1_state";

  const IDLE_MS = 30000;

  // Low power autoscroll
  const AUTOSCROLL_TICK_MS = 120;   // ~8 fps
  const AUTOSCROLL_STEP_PX = 0.7;
  const AUTOSCROLL_RESUME_MS = 3500;

  // ✅ Embedded starter list so guide is never blank
  // (These are safe/demo sources; you can replace/extend later.)
  const EMBEDDED_STARTER = [
    {name:"Big Buck Bunny (MP4)", url:"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4", mode:"mp4", language:"English", group:"Demo", type:"general", tags:["mp4","demo"]},
    {name:"Sintel (MP4)", url:"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4", mode:"mp4", language:"English", group:"Demo", type:"general", tags:["mp4","demo"]},
    // A few known-public HLS test streams (not “TV channels”, just stable HLS sources)
    {name:"HLS Test (bipbop)", url:"https://devstreaming-cdn.apple.com/videos/streaming/examples/bipbop_16x9/bipbop_16x9_variant.m3u8", mode:"hls", language:"English", group:"Test", type:"general", tags:["hls","test"]},
    {name:"HLS Test (advanced stream)", url:"https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8", mode:"hls", language:"English", group:"Test", type:"general", tags:["hls","test"]},
    // Your FAST services (open in tab)
    {name:"Pluto TV", url:"https://pluto.tv/live-tv", mode:"tab", language:"English", group:"FAST", type:"general", tags:["fast","tab"]},
    {name:"Tubi Live", url:"https://tubitv.com/live", mode:"tab", language:"English", group:"FAST", type:"general", tags:["fast","tab"]},
    {name:"The Roku Channel", url:"https://therokuchannel.roku.com", mode:"tab", language:"English", group:"FAST", type:"general", tags:["fast","tab"]}
  ];

  const DEFAULT_STATE = {
    channels: EMBEDDED_STARTER.map((c,i)=>({id:"seed_"+i, ...c})),
    sources: [ DEFAULT_ENG_PLAYLIST ],
    favorites: {},
    sleepTags: {},
    audioOnly: {},
    ui: {
      playableOnly: true,
      hideAudioOnly: true,
      autoScroll: true,
      autoTheater: false,
      theater: false
    }
  };

  let state = loadState();
  function loadState(){
    try{
      const raw = localStorage.getItem(KEY);
      if(!raw) return structuredClone(DEFAULT_STATE);
      const s = JSON.parse(raw);
      if(!Array.isArray(s.channels) || s.channels.length === 0) s.channels = structuredClone(DEFAULT_STATE.channels);
      if(!Array.isArray(s.sources)) s.sources = [DEFAULT_ENG_PLAYLIST];
      if(!s.favorites) s.favorites = {};
      if(!s.sleepTags) s.sleepTags = {};
      if(!s.audioOnly) s.audioOnly = {};
      if(!s.ui) s.ui = structuredClone(DEFAULT_STATE.ui);
      if(!s.sources.includes(DEFAULT_ENG_PLAYLIST)) s.sources.unshift(DEFAULT_ENG_PLAYLIST);
      return s;
    }catch{
      return structuredClone(DEFAULT_STATE);
    }
  }
  function saveState(){ localStorage.setItem(KEY, JSON.stringify(state)); }

  const body = document.body;
  const guide = document.getElementById("guide");
  const list = document.getElementById("list");
  const player = document.getElementById("player");

  const statusEl = document.getElementById("status");
  const countEl = document.getElementById("count");
  const nowEl = document.getElementById("nowPlaying");
  const modeBadge = document.getElementById("modeBadge");
  const clockEl = document.getElementById("clock");

  const emptyCallout = document.getElementById("emptyCallout");
  const btnImportEng = document.getElementById("btnImportEng");
  const btnImportFileTop = document.getElementById("btnImportFileTop");

  const qEl = document.getElementById("q");
  const groupEl = document.getElementById("group");
  const langEl = document.getElementById("lang");
  const typeEl = document.getElementById("type");

  const playableOnlyEl = document.getElementById("playableOnly");
  const hideAudioOnlyEl = document.getElementById("hideAudioOnly");
  const autoScrollEl = document.getElementById("autoScroll");
  const autoTheaterEl = document.getElementById("autoTheater");

  const btnOpenTab = document.getElementById("btnOpenTab");
  const btnResetUI = document.getElementById("btnResetUI");

  const pvFrame = document.getElementById("pvFrame");
  const pvVideo = document.getElementById("pvVideo");

  const tPrev = document.getElementById("tPrev");
  const tPlay = document.getElementById("tPlay");
  const tNext = document.getElementById("tNext");
  const tTheater = document.getElementById("tTheater");
  const tFS = document.getElementById("tFS");
  const tRecover = document.getElementById("tRecover");

  function setStatus(msg){ statusEl.textContent = msg; }
  function escapeHtml(s){
    return String(s).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;")
      .replaceAll('"',"&quot;").replaceAll("'","&#039;");
  }
  function uniq(arr){ return [...new Set(arr)].filter(Boolean).sort((a,b)=>a.localeCompare(b)); }
  function hash(s){
    let h = 2166136261;
    for(let i=0;i<s.length;i++){ h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
    return (h>>>0).toString(16);
  }
  function normalizeMode(url){
    const u = (url||"").toLowerCase();
    if(u.includes(".m3u8")) return "hls";
    if(u.includes(".mp4")) return "mp4";
    return "tab";
  }
  function guessType(group, name){
    const g = (group||"").toLowerCase();
    const n = (name||"").toLowerCase();
    if(g.includes("news") || n.includes("news")) return "news";
    if(g.includes("sport") || n.includes("sport")) return "sports";
    if(g.includes("movie") || n.includes("movie") || g.includes("cinema")) return "movies";
    if(g.includes("music") || n.includes("music") || g.includes("radio")) return "music";
    if(g.includes("education") || g.includes("science") || n.includes("nasa")) return "education";
    return "general";
  }

  function setTheater(on){
    state.ui.theater = !!on;
    body.classList.toggle("theater", !!on);
    tTheater.classList.toggle("on", !!on);
    saveState();
  }

  async function toggleFullscreen(){
    try{
      const el = player;
      if(document.fullscreenElement) await document.exitFullscreen();
      else await el.requestFullscreen({ navigationUI: "hide" });
    }catch{
      setStatus("Fullscreen blocked by browser.");
    }
  }

  // Idle
  let idleTimer = null;
  function setIdle(v){
    body.classList.toggle("idle", v);
    if(v && state.ui.autoTheater) setTheater(true);
  }
  function resetIdle(){
    setIdle(false);
    if(idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(()=>setIdle(true), IDLE_MS);
  }
  ["mousemove","mousedown","keydown","wheel","touchstart","touchmove"].forEach(evt=>{
    window.addEventListener(evt, resetIdle, {passive:true});
  });

  // Autoscroll (low power + pause on interaction)
  let autoScrollTimer = null;
  let guideInteracting = false;
  let guideInteractionTimer = null;

  function shouldAutoscroll(){
    if(!state.ui.autoScroll) return false;
    if(guideInteracting) return false;
    if(body.classList.contains("idle")) return false;
    if(state.ui.theater) return false;
    return true;
  }
  function startAutoscroll(){
    stopAutoscroll();
    autoScrollTimer = setInterval(()=>{
      if(!shouldAutoscroll()) return;
      if(list.scrollHeight <= list.clientHeight) return;
      list.scrollTop += AUTOSCROLL_STEP_PX;
      if(list.scrollTop >= (list.scrollHeight - list.clientHeight - 2)) list.scrollTop = 0;
    }, AUTOSCROLL_TICK_MS);
  }
  function stopAutoscroll(){
    if(autoScrollTimer) clearInterval(autoScrollTimer);
    autoScrollTimer = null;
  }
  function pauseAutoscroll(){
    if(!state.ui.autoScroll) return;
    guideInteracting = true;
    if(guideInteractionTimer) clearTimeout(guideInteractionTimer);
    guideInteractionTimer = setTimeout(()=>{ guideInteracting = false; }, AUTOSCROLL_RESUME_MS);
  }
  ["pointerdown","pointermove","touchstart","touchmove","mousedown","mousemove","click","wheel"].forEach(evt=>{
    guide.addEventListener(evt, pauseAutoscroll, {passive:true});
  });
  list.addEventListener("scroll", pauseAutoscroll, {passive:true});

  // Playback
  let hls = null;
  let current = null;
  let selectedIndex = 0;
  let filtered = [];

  function stopHls(){ if(hls){ try{ hls.destroy(); }catch{} hls=null; } }
  function showVideo(){ pvVideo.style.display="block"; pvFrame.style.display="none"; }
  function showFrame(){ pvVideo.style.display="none"; pvFrame.style.display="block"; }

  function play(ch){
    if(!ch) return;
    current = ch;
    saveState();

    const mode = (ch.mode||"tab").toLowerCase();
    nowEl.textContent = `Playing: ${ch.name||"Unnamed"}`;
    modeBadge.textContent = `mode: ${mode}`;
    setStatus(`Loading: ${ch.name||"Unnamed"}`);

    stopHls();
    try{ pvVideo.pause(); }catch{}

    if(mode === "tab"){
      showFrame();
      pvFrame.src = "about:blank";
      try{ window.open(ch.url, "_blank"); }catch{}
      setStatus(`Opened in tab: ${ch.name}`);
      return;
    }

    if(mode === "mp4"){
      showVideo();
      pvVideo.src = ch.url;
      pvVideo.play().then(()=>setStatus(`Playing (MP4): ${ch.name}`))
        .catch(()=>setStatus("Tap play in the video controls (autoplay blocked)."));
      return;
    }

    if(mode === "hls"){
      showVideo();
      const url = ch.url;
      if(pvVideo.canPlayType("application/vnd.apple.mpegurl")){
        pvVideo.src = url;
        pvVideo.play().then(()=>setStatus(`Playing (HLS): ${ch.name}`))
          .catch(()=>setStatus("Tap play in the video controls (autoplay blocked)."));
        return;
      }
      if(window.Hls && window.Hls.isSupported()){
        hls = new window.Hls({ enableWorker:true, maxBufferLength:30 });
        hls.loadSource(url);
        hls.attachMedia(pvVideo);
        pvVideo.play().then(()=>setStatus(`Playing (HLS): ${ch.name}`))
          .catch(()=>setStatus("Tap play in the video controls (autoplay blocked)."));
        return;
      }
      setStatus("HLS not supported in this browser.");
      return;
    }
  }

  function playSelected(){ if(filtered.length) play(filtered[selectedIndex]); }
  function moveSelection(delta){
    if(!filtered.length) return;
    selectedIndex = (selectedIndex + delta + filtered.length) % filtered.length;
    render();
  }

  // Filters + render
  function rebuildOptions(){
    const groups = uniq(state.channels.map(c=>c.group));
    groupEl.innerHTML = `<option value="">Group (all)</option>` + groups.map(g=>`<option value="${escapeHtml(g)}">${escapeHtml(g)}</option>`).join("");
    const langs = uniq(state.channels.map(c=>c.language));
    langEl.innerHTML = `<option value="">Language (all)</option>` + langs.map(l=>`<option value="${escapeHtml(l)}">${escapeHtml(l)}</option>`).join("");
  }

  function matches(ch){
    const q = qEl.value.trim().toLowerCase();
    const group = groupEl.value;
    const lang = langEl.value;
    const type = typeEl.value;

    const mode = (ch.mode||"tab");
    if(state.ui.playableOnly && !(mode==="hls" || mode==="mp4")) return false;
    if(state.ui.hideAudioOnly && state.audioOnly[ch.url]) return false;

    if(group && ch.group !== group) return false;
    if(lang && ch.language !== lang) return false;
    if(type && ch.type !== type) return false;

    const blob = `${ch.name||""} ${(ch.tags||[]).join(" ")} ${ch.language||""} ${ch.group||""} ${ch.type||""} ${ch.url||""}`.toLowerCase();
    if(q && !blob.includes(q)) return false;
    return true;
  }

  function render(){
    // If channels somehow got nuked, restore embedded starter list
    if(!state.channels || state.channels.length === 0){
      state.channels = structuredClone(DEFAULT_STATE.channels);
      saveState();
    }

    filtered = state.channels.filter(matches);

    // ✅ show empty callout if no results
    const empty = filtered.length === 0;
    emptyCallout.style.display = empty ? "grid" : "none";

    if(empty){
      list.innerHTML = `<div class="item"><div class="row"><div class="name">No matches</div></div>
        <div class="meta">Try unchecking “Playable only”, or tap Import English Playlist above.</div></div>`;
      countEl.textContent = "0";
      return;
    }

    selectedIndex = Math.max(0, Math.min(selectedIndex, filtered.length-1));
    list.innerHTML = filtered.map((c, idx)=>{
      const selected = idx===selectedIndex ? "selected" : "";
      const mode = (c.mode||"tab");
      const modeTag = mode==="hls" ? `<span class="tag good">hls</span>` :
                     mode==="mp4" ? `<span class="tag good">mp4</span>` :
                     `<span class="tag warn">tab</span>`;
      const tags = [c.language, c.group, c.type, ...(c.tags||[])].filter(Boolean).slice(0,5);
      return `
        <div class="item ${selected}" data-idx="${idx}">
          <div class="row">
            <div class="name">▶ ${escapeHtml(c.name||"Unnamed")}</div>
            <div class="meta">${modeTag}</div>
          </div>
          <div class="tags">${tags.map(t=>`<span class="tag">${escapeHtml(t)}</span>`).join("")}</div>
          <div class="meta">${escapeHtml(c.url||"")}</div>
        </div>
      `;
    }).join("");
    countEl.textContent = String(filtered.length);
  }

  list.addEventListener("click", (e)=>{
    const item = e.target.closest(".item");
    if(!item) return;
    const idx = Number(item.getAttribute("data-idx"));
    if(Number.isFinite(idx)){
      selectedIndex = idx;
      render();
      playSelected();
    }
  });

  // Top buttons
  btnOpenTab.addEventListener("click", ()=>{
    if(!current || !current.url){ setStatus("Nothing playing yet."); return; }
    window.open(current.url, "_blank");
  });

  btnResetUI.addEventListener("click", async ()=>{
    // Only reset UI flags, keep channels
    state.ui = structuredClone(DEFAULT_STATE.ui);
    saveState();
    applyUi();
    setTheater(false);
    body.classList.remove("idle");
    try{ if(document.fullscreenElement) await document.exitFullscreen(); }catch{}
    setStatus("UI reset.");
    render();
    resetIdle();
  });

  // Touch bar
  tPrev.addEventListener("click", ()=> moveSelection(-1));
  tNext.addEventListener("click", ()=> moveSelection(1));
  tPlay.addEventListener("click", ()=> playSelected());
  tTheater.addEventListener("click", ()=> { setTheater(!state.ui.theater); resetIdle(); });
  tFS.addEventListener("click", ()=> { toggleFullscreen(); resetIdle(); });

  tRecover.addEventListener("click", async ()=>{
    try{ setTheater(false); body.classList.remove("idle"); }catch{}
    try{ if(document.fullscreenElement) await document.exitFullscreen(); }catch{}
    try{
      if(current){
        const ch = current;
        stopHls();
        pvVideo.pause(); pvVideo.src = "";
        setTimeout(()=>play(ch), 150);
      }
    }catch{}
    setStatus("Recovered. Tap Play if needed.");
    resetIdle();
  });

  // UI toggles
  function applyUi(){
    playableOnlyEl.checked = !!state.ui.playableOnly;
    hideAudioOnlyEl.checked = !!state.ui.hideAudioOnly;
    autoScrollEl.checked = !!state.ui.autoScroll;
    autoTheaterEl.checked = !!state.ui.autoTheater;
    setTheater(!!state.ui.theater);
  }
  function saveUi(){
    state.ui.playableOnly = playableOnlyEl.checked;
    state.ui.hideAudioOnly = hideAudioOnlyEl.checked;
    state.ui.autoScroll = autoScrollEl.checked;
    state.ui.autoTheater = autoTheaterEl.checked;
    saveState();
  }

  [qEl, groupEl, langEl, typeEl].forEach(el=>{
    el.addEventListener("input", ()=>{ selectedIndex=0; render(); });
    el.addEventListener("change", ()=>{ selectedIndex=0; render(); });
  });
  [playableOnlyEl, hideAudioOnlyEl, autoScrollEl, autoTheaterEl].forEach(el=>{
    el.addEventListener("change", ()=>{
      saveUi();
      selectedIndex=0;
      render();
      if(state.ui.autoScroll && !autoScrollTimer) startAutoscroll();
      if(!state.ui.autoScroll) stopAutoscroll();
    });
  });

  // Import English playlist button
  btnImportEng.addEventListener("click", ()=> importFromUrl(DEFAULT_ENG_PLAYLIST));
  btnImportFileTop.addEventListener("click", ()=> importFilePicker());

  function parseExtinfAttrs(line){
    const attrs = {};
    const re = /([a-zA-Z0-9\-_:]+)="([^"]*)"/g;
    let m; while((m = re.exec(line)) !== null) attrs[m[1]] = m[2];
    const commaIdx = line.lastIndexOf(",");
    attrs.__displayName = commaIdx >= 0 ? line.slice(commaIdx+1).trim() : "";
    return attrs;
  }

  async function importM3UText(text, sourceLabel){
    setStatus("Parsing playlist…");
    const lines = text.split(/\r?\n/);
    const total = lines.length;

    const imported = [];
    let lastExt = null;

    for(let i=0;i<total;i++){
      const line = lines[i].trim();
      if(!line) continue;
      if(line.startsWith("#EXTINF")) lastExt = parseExtinfAttrs(line);
      else if(!line.startsWith("#")){
        const url = line;
        const name = (lastExt && (lastExt["tvg-name"] || lastExt.__displayName)) || url;
        const group = (lastExt && (lastExt["group-title"] || "Imported")) || "Imported";
        const lang  = (lastExt && (lastExt["tvg-language"] || "English")) || "English";
        const mode = normalizeMode(url);
        const type = guessType(group, name);
        imported.push({
          id:`m3u_${hash(name+"|"+url)}`,
          name, url, mode, language: lang, group, type,
          tags: ["m3u", group].filter(Boolean)
        });
        lastExt = null;
      }
      if(i % 900 === 0){
        // tiny UI yield
        await new Promise(r=>setTimeout(r,0));
      }
    }

    const byUrl = new Map(state.channels.map(c=>[c.url,c]));
    let added = 0;
    for(const ch of imported){
      if(!byUrl.has(ch.url)){ byUrl.set(ch.url,ch); added++; }
    }
    state.channels = Array.from(byUrl.values());
    saveState();
    rebuildOptions();
    render();
    setStatus(`Import done: +${added} channels`);
  }

  async function importFromUrl(url){
    setStatus("Fetching playlist…");
    try{
      const res = await fetch(url, {cache:"no-store"});
      if(!res.ok) throw new Error(`HTTP ${res.status}`);
      await importM3UText(await res.text(), url);
    }catch(err){
      setStatus("Import failed. Use Import File.");
      // Show the empty callout so they see the Import File button
      emptyCallout.style.display = "grid";
    }
  }

  function importFilePicker(){
    const input = document.createElement("input");
    input.type="file";
    input.accept=".m3u,.m3u8,text/plain,application/octet-stream";
    input.onchange=()=>{
      const f=input.files && input.files[0];
      if(!f) return;
      const reader = new FileReader();
      reader.onload = async ()=>{ await importM3UText(String(reader.result||""), f.name); };
      reader.onerror = ()=> setStatus("Could not read file.");
      reader.readAsText(f);
    };
    input.click();
  }

  // Clock
  function tickClock(){
    const d = new Date();
    clockEl.textContent = `${String(d.getHours()).padStart(2,"0")}:${String(d.getMinutes()).padStart(2,"0")}`;
  }
  setInterval(tickClock, 1000); tickClock();

  // Init
  applyUi();
  rebuildOptions();
  render();
  resetIdle();

  if(state.ui.autoScroll) startAutoscroll();

  // Try auto-import once (won’t break if it fails)
  const hasAnyM3U = state.channels.some(c => (c.tags||[]).includes("m3u"));
  if(!hasAnyM3U){
    // do not force; just attempt
    importFromUrl(DEFAULT_ENG_PLAYLIST);
  }
})();
</script>
</body>
