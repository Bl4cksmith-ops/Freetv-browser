(() => {
  const DEFAULT_ENG_PLAYLIST = "https://iptv-org.github.io/iptv/languages/eng.m3u";
  const KEY = "free_tv_v12_2_state";

  const IDLE_MS = 30_000;

  // Low-power autoscroll settings
  const AUTOSCROLL_TICK_MS = 100;      // 10 fps
  const AUTOSCROLL_STEP_PX = 0.6;      // per tick
  const AUTOSCROLL_RESUME_MS = 3500;   // after interaction
  const PAUSE_AUTOSCROLL_WHILE_PLAYING_STREAM = true; // safer on weak devices

  const DEFAULT_STATE = {
    channels: [
      { id:"pluto", name:"Pluto TV", mode:"tab", url:"https://pluto.tv/live-tv", language:"English", group:"FAST", type:"general", tags:["fast","tab"] },
      { id:"tubi",  name:"Tubi Live", mode:"tab", url:"https://tubitv.com/live", language:"English", group:"FAST", type:"general", tags:["fast","tab"] },
      { id:"roku",  name:"The Roku Channel", mode:"tab", url:"https://therokuchannel.roku.com", language:"English", group:"FAST", type:"general", tags:["fast","tab"] },
      { id:"mp4-bunny", name:"Big Buck Bunny (MP4 sample)", mode:"mp4",
        url:"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4",
        language:"English", group:"Demo", type:"general", tags:["demo","mp4"]
      }
    ],
    sources: [ DEFAULT_ENG_PLAYLIST ],
    favorites: {},
    sleepTags: {},
    recents: [],
    audioOnly: {},
    ui: {
      playableOnly: true,
      hideAudioOnly: true,
      onlyFavs: false,
      onlySleep: false,
      autoScroll: true,      // ON by default
      autoTheater: false,    // OFF by default (stability)
      theater: false
    }
  };

  let state = loadState();
  function loadState(){
    try{
      const raw = localStorage.getItem(KEY);
      if(!raw) return structuredClone(DEFAULT_STATE);
      const s = JSON.parse(raw);
      if(!Array.isArray(s.channels)) s.channels = [];
      if(!Array.isArray(s.sources)) s.sources = [DEFAULT_ENG_PLAYLIST];
      if(!s.favorites) s.favorites = {};
      if(!s.sleepTags) s.sleepTags = {};
      if(!Array.isArray(s.recents)) s.recents = [];
      if(!s.audioOnly) s.audioOnly = {};
      if(!s.ui) s.ui = structuredClone(DEFAULT_STATE.ui);
      if(!s.sources.includes(DEFAULT_ENG_PLAYLIST)) s.sources.unshift(DEFAULT_ENG_PLAYLIST);
      return s;
    }catch{
      return structuredClone(DEFAULT_STATE);
    }
  }
