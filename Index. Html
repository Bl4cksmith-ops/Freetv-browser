  function setStatus(msg){ statusEl.textContent = msg; }
  function escapeHtml(s){
    return String(s).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;")
      .replaceAll('"',"&quot;").replaceAll("'","&#039;");
  }
  function uniq(arr){ return [...new Set(arr)].filter(Boolean).sort((a,b)=>a.localeCompare(b)); }
  function hash(s){
    let h = 2166136261;
    for(let i=0;i<s.length;i++){ h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
    return (h>>>0).toString(16);
  }
  function normalizeMode(url){
    const u = (url||"").toLowerCase();
    if(u.includes(".m3u8")) return "hls";
    if(u.includes(".mp4")) return "mp4";
    return "tab";
  }
  function guessType(group, name){
    const g = (group||"").toLowerCase();
    const n = (name||"").toLowerCase();
    if(g.includes("news") || n.includes("news")) return "news";
    if(g.includes("sport") || n.includes("sport")) return "sports";
    if(g.includes("movie") || n.includes("movie") || g.includes("cinema")) return "movies";
    if(g.includes("music") || n.includes("music") || g.includes("radio")) return "music";
    if(g.includes("education") || g.includes("science") || n.includes("nasa")) return "education";
    return "general";
  }

  function setTheater(on){
    state.ui.theater = !!on;
    body.classList.toggle("theater", !!on);
    tTheater.classList.toggle("on", !!on);
    saveState();
  }

  async function toggleFullscreen(){
    try{
      const el = player;
      if(document.fullscreenElement) await document.exitFullscreen();
      else await el.requestFullscreen({ navigationUI: "hide" });
    }catch{
      setStatus("Fullscreen blocked by browser; use Theater.");
    }
