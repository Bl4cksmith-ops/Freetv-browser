<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1, maximum-scale=1"/>
  <title>Free TV v12.2 (Stable Touch + Low-Power Autoscroll)</title>
  <style>
    :root{
      --bg:#0b0f17;
      --panel:rgba(18,24,38,.92);
      --panelBorder:rgba(255,255,255,.10);
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.65);
      --accent:#7c5cff;
      --good:#2dd4bf;
      --warn:#fb7185;
      --shadow:0 10px 30px rgba(0,0,0,.35);
      --radius:16px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      background:var(--bg);
      color:var(--text);
      overflow:hidden;
      touch-action: manipulation;
    }

    .app{height:100vh;width:100vw;display:grid;grid-template-columns: 400px 1fr;}
    .guide{min-height:0;min-width:0}
    .list{min-height:0;min-width:0;overflow-y:auto;overscroll-behavior:contain}
    .player{position:relative;overflow:hidden;background:#000}

    .theater .app{ grid-template-columns: 0 1fr; }
    .theater .guide{ display:none; }

    .guide{
      background:var(--panel);
      border-right:1px solid var(--panelBorder);
      padding:12px;
      display:grid;
      grid-template-rows:auto auto auto auto 1fr auto;
      gap:10px;
      opacity:1;
      transform:translateX(0);
      transition:opacity 1.2s ease, transform 1.2s ease;
      will-change:opacity,transform;
    }
    .idle .guide{opacity:.06;transform:translateX(-10px)}

    .hdr{display:flex;align-items:center;justify-content:space-between;gap:10px}
    .title{font-weight:820;letter-spacing:.2px;display:flex;align-items:center;gap:10px}
    .pill{
      font-size:12px;padding:4px 10px;border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(0,0,0,.25);
      color:rgba(255,255,255,.85);
      white-space:nowrap;
    }
    .sub{color:var(--muted);font-size:12px;line-height:1.35}

    .controls{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    input,select,button,textarea,label{font:inherit}
    input,select{
      width:100%;padding:10px;border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);
      color:var(--text);
      outline:none;
    }

    button{
      padding:10px;border-radius:12px;border:1px solid rgba(255,255,255,.12);
      background:rgba(124,92,255,.15);color:rgba(255,255,255,.92);
      cursor:pointer;box-shadow:var(--shadow);
    }
    button.secondary{background:rgba(255,255,255,.06);box-shadow:none}
    button.danger{background:rgba(251,113,133,.15)}
    button:active{transform:translateY(1px)}

    .toggleRow{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .toggle{
      display:flex;align-items:center;gap:10px;
      padding:10px;border-radius:12px;border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);color:rgba(255,255,255,.88);user-select:none;
    }
    .toggle input{width:auto}

    .list{
      border-radius:var(--radius);
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.03);
    }
    .item{
      padding:12px;border-bottom:1px solid rgba(255,255,255,.08);
      display:grid;gap:6px;cursor:pointer;
    }
    .item:last-child{border-bottom:none}
    .item.selected{outline:2px solid rgba(124,92,255,.55);background:rgba(124,92,255,.10)}
    .row{display:flex;align-items:center;justify-content:space-between;gap:10px}
    .name{font-weight:760}
    .meta{color:var(--muted);font-size:12px}
    .tags{display:flex;flex-wrap:wrap;gap:6px;align-items:center}
    .tag{
      font-size:11px;padding:4px 8px;border-radius:999px;
      border:1px solid rgba(124,92,255,.28);background:rgba(124,92,255,.14);
      color:rgba(230,225,255,.92);
      max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap
    }
    .tag.good{border-color:rgba(45,212,191,.35);background:rgba(45,212,191,.13)}
    .tag.warn{border-color:rgba(251,113,133,.38);background:rgba(251,113,133,.12)}
    .tag.star{border-color:rgba(255,215,0,.35);background:rgba(255,215,0,.12);color:rgba(255,245,200,.95)}
    .tag.moon{border-color:rgba(200,200,255,.35);background:rgba(200,200,255,.12);color:rgba(240,240,255,.95)}

    .footer{display:flex;align-items:center;justify-content:space-between;gap:10px;color:var(--muted);font-size:12px}

    .frameWrap{position:absolute;inset:0;transition:transform 1.2s ease;will-change:transform}
    .idle .frameWrap{transform:scale(1.02)}
    iframe,video{width:100%;height:100%;border:0;background:#000}

    .overlayTop{
      position:absolute;top:12px;left:12px;right:12px;
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      pointer-events:none;z-index:9;
    }
    .chip{
      background:rgba(0,0,0,.45);border:1px solid rgba(255,255,255,.12);
      padding:8px 10px;border-radius:999px;color:rgba(255,255,255,.90);
      font-size:12px;max-width:60%;
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    }
    .overlayBottom{
      position:absolute;left:12px;right:12px;bottom:12px;
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      pointer-events:none;z-index:9;
    }
    .hint{
      color:rgba(255,255,255,.70);font-size:12px;
      background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.10);
      padding:8px 10px;border-radius:999px;max-width:55%;
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    }

    .touchBar{
      position:absolute;left:12px;right:12px;bottom:64px;
      display:flex;gap:8px;flex-wrap:wrap;
      justify-content:center;align-items:center;
      z-index:10;
    }
    .touchBtn{
      pointer-events:auto;
      border-radius:999px;padding:10px 14px;
      background:rgba(0,0,0,.42);
      border:1px solid rgba(255,255,255,.14);
      color:rgba(255,255,255,.92);
      box-shadow: var(--shadow);
      user-select:none;font-size:13px;
    }
    .touchBtn.on{ border-color: rgba(124,92,255,.6); background: rgba(124,92,255,.22); }
    .touchBtn.good{ border-color: rgba(45,212,191,.5); background: rgba(45,212,191,.16); }
    .touchBtn.warn{ border-color: rgba(251,113,133,.55); background: rgba(251,113,133,.18); }

    .modal{
      position:fixed;inset:0;background:rgba(0,0,0,.55);
      display:none;align-items:center;justify-content:center;padding:20px;z-index:50;
    }
    .modal.on{display:flex}
    .card{
      width:min(1100px,96vw);max-height:90vh;overflow:auto;
      border-radius:20px;background:rgba(18,24,38,.96);
      border:1px solid rgba(255,255,255,.12);
      box-shadow:var(--shadow);padding:16px;display:grid;gap:12px;
    }
    .card h2{margin:0;font-size:16px}
    textarea{
      width:100%;min-height:140px;padding:12px;border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);color:var(--text);outline:none;resize:vertical
    }
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .small{font-size:12px;color:var(--muted);line-height:1.35}
    .actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap}
    .progressBar{height:10px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;border:1px solid rgba(255,255,255,.10)}
    .progressBar>div{height:100%;width:0%;background:linear-gradient(90deg, rgba(124,92,255,.9), rgba(45,212,191,.85));transition:width .2s ease}
  </style>
</head>
<body>

<div id="root">
  <div class="app" id="app">
    <aside class="guide" id="guide">
      <div class="hdr">
        <div class="title">Free TV <span class="pill">v12.2 stable</span></div>
        <div class="pill" id="clock">--:--</div>
      </div>

      <div class="sub">
        Autoscroll is low-power and pauses on guide interaction. Idle fade stays. Auto-theater is OFF by default.
      </div>

      <div class="controls">
        <input id="q" placeholder="Search (name/tags/url)" />
        <select id="group"><option value="">Group (all)</option></select>
        <select id="lang"><option value="">Language (all)</option></select>
        <select id="type">
          <option value="">Type (all)</option>
          <option value="news">News</option>
          <option value="sports">Sports</option>
          <option value="movies">Movies</option>
          <option value="music">Music</option>
          <option value="education">Education</option>
          <option value="general">General</option>
        </select>
      </div>

      <div class="toggleRow">
        <label class="toggle"><input type="checkbox" id="playableOnly"/> Playable only (HLS/MP4)</label>
        <label class="toggle"><input type="checkbox" id="hideAudioOnly"/> Hide audio-only</label>
        <label class="toggle"><input type="checkbox" id="onlyFavs"/> Favorites</label>
        <label class="toggle"><input type="checkbox" id="onlySleep"/> Sleep channels</label>
      </div>

      <div class="toggleRow">
        <label class="toggle"><input type="checkbox" id="autoScroll"/> Guide autoscroll</label>
        <label class="toggle"><input type="checkbox" id="autoTheater"/> Auto theater on idle</label>
      </div>

      <div class="controls">
        <button class="secondary" id="btnOpenTab">Open Tab</button>
        <button class="secondary" id="btnPanel">Playlists</button>
      </div>

      <div class="list" id="list" tabindex="0"></div>

      <div class="footer">
        <div id="status">Ready</div>
        <div id="count">0</div>
      </div>
    </aside>

    <main class="player" id="player">
      <div class="frameWrap">
        <iframe
          id="pvFrame"
          sandbox="allow-scripts allow-forms allow-same-origin allow-popups allow-presentation"
          allow="autoplay; encrypted-media; picture-in-picture; fullscreen"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
        <video id="pvVideo" controls playsinline style="display:none"></video>
      </div>

      <div class="overlayTop">
        <div class="chip" id="nowPlaying">No channel</div>
        <div class="chip" id="modeBadge">mode: —</div>
      </div>

      <div class="touchBar" id="touchBar">
        <div class="touchBtn" id="tPrev">⟵ Prev</div>
        <div class="touchBtn good" id="tPlay">▶ Play</div>
        <div class="touchBtn" id="tNext">Next ⟶</div>
        <div class="touchBtn" id="tFav">⭐ Favorite</div>
        <div class="touchBtn" id="tSleep">🌙 Sleep</div>
        <div class="touchBtn" id="tGuide">📋 Guide</div>
        <div class="touchBtn" id="tTheater">⬛ Theater</div>
        <div class="touchBtn" id="tFS">⛶ Fullscreen</div>
        <div class="touchBtn warn" id="tRecover">🧯 Recover</div>
      </div>

      <div class="overlayBottom">
        <div class="hint" id="idleHint">active</div>
        <div class="hint" id="autoHint">autoscroll: —</div>
      </div>
    </main>
  </div>

  <div class="modal" id="modal">
    <div class="card">
      <div class="hdr">
        <h2>Playlists</h2>
        <button class="secondary" id="btnClose">Close</button>
      </div>

      <div class="small"><b>Default English playlist</b>: https://iptv-org.github.io/iptv/languages/eng.m3u</div>

      <div class="grid2">
        <div>
          <div class="small">Playlist URL</div>
          <input id="m3uUrl" placeholder="https://..." />
          <div style="height:8px"></div>
          <div class="controls" style="grid-template-columns:1fr 1fr">
            <button id="btnImportUrl">Import URL</button>
            <button class="secondary" id="btnImportFile">Import File</button>
          </div>
          <div style="height:10px"></div>
          <div class="small">Progress</div>
          <div class="progressBar"><div id="progressFill"></div></div>
          <div class="small" id="importMsg" style="margin-top:8px"></div>
        </div>
        <div>
          <div class="small">Saved playlists (one per line)</div>
          <textarea id="sourcesBox"></textarea>
          <div class="actions">
            <button class="danger" id="btnResetAll">Reset Everything</button>
            <button id="btnSaveSources">Save Playlists</button>
          </div>
          <div class="small" id="sourcesMsg"></div>
        </div>
      </div>
    </div>
  </div>
</div>

